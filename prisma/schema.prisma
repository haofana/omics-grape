  typeOfPetiolarSinusRestrictionByVeinsOnMatureLeaf        String? @map("typeofpetiolarsinusrestrictionbyveinsonmatureleaf")
  blisteringOfMatureLeaf                                   String? @map("blisteringofmatureleaf")
  depthOfUpperLobesOnMatureLeaf                            String? @map("depthofupperlobesonmatureleaf")
  overlappingTypeOfUpperLobesOnMatureLeaf                  String? @map("overlappingtypeofupperlobesonmatureleaf")
  overlappingTypeOfLowerLobesOnMatureLeaf                  String? @map("overlappingtypeoflowerlobesonmatureleaf")
