generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DownloadList {
  key     Int     @id @default(autoincrement())
  Species String  @db.VarChar(255)
  Genome  String? @db.VarChar(255)
  GFF     String? @db.VarChar(50)
  CDS     String? @db.VarChar(50)
  mRNA    String? @db.VarChar(50)
  Protein String? @db.VarChar(50)
}

model Germplasm {
  id      Int     @id @map("id")
  variety String? @map("variety")
  feature String? @map("feature")
  stage   String? @map("stage")
  type    String? @map("type")
  unit    String? @map("unit")

  @@map("germplasm")
}

model PhenomicsFruit {
  no                   Int     @id
  variety              String?
  scientific           String? @map("grapescientificname")
  aromaType            String? @map("aromatype")
  aromaIntensity       String? @map("aromaintensity")
  berrySize            String? @map("berrysize")
  singleBerryWeight    String? @map("singleberryweight")
  fruitShapeIndex      String? @map("fruitshapeindex")
  fruitShape           String? @map("fruitshape")
  solubleSolidsContent String? @map("solublesolidscontent")
  titratableAcid       String? @map("titratableacid")
  sugarAcidRatio       String? @map("sugaracidratio")
  tartaricAcid         String? @map("tartaricacid")
  citricAcid           String? @map("citricacid")
  malicAcid            String? @map("malicacid")
  fructose             String? @map("fructose")
  glucose              String? @map("glucose")
  fleshFirmness        String? @map("fleshfirmness")
  skinFirmness         String? @map("skinfirmness")
  fleshCellulose       String? @map("fleshcellulose")
  skinCellulose        String? @map("skincellulose")
  skinHemicellulose    String? @map("skinhemicellulose")
  fleshHemicellulose   String? @map("fleshhemicellulose")
  maturityPeriod       String? @map("maturityperiod")
  berryPhotos          String? @map("berryphotos")

  @@map("phenomics_fruit")
}

model PhenomicsLeaf {
  no                                                       Int     @id @map("no")
  variety                                                  String? @map("variety")
